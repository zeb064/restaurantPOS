# =============================================================================
# Supabase (Requerido - Obtener del dashboard del proyecto Supabase)
# =============================================================================
# Ve a: https://supabase.com/dashboard/project/<tu-project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://<tu-project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<tu-anon-key>

# Solo para acciones del servidor (NO exponer al cliente)
SUPABASE_SERVICE_ROLE_KEY=<tu-service-role-key>

# =============================================================================
# Base de Datos (Para Drizzle ORM y migraciones)
# =============================================================================
# Connection string de Supabase: https://supabase.com/dashboard/project/<tu-project>/settings/database
DATABASE_URL=postgresql://postgres:<password>@db.<tu-project>.supabase.co:5432/postgres

# =============================================================================
# Aplicación
# =============================================================================
# URL base (cambiar en producción)
NEXT_PUBLIC_APP_URL=http://localhost:3000
